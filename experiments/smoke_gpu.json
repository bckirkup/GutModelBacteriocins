{
  "_comment": [
    "Tiny CUDA smoke for AWS Batch practice (docs/AWS_BATCH.md Phase 1).",
    "Same scale as smoke_single but gpu_enabled. Chemistry grid is tiny",
    "(~8k cells) — fits g4dn.xlarge comfortably. Not a science run."
  ],
  "total_time": 120,
  "bio_dt": 60,
  "output_interval": 1000000000,
  "seed": 4092,
  "domain_x": 0.0001,
  "domain_y": 0.0001,
  "domain_z": 0.00005,
  "grid_dx": 0.000005,
  "gpu_enabled": true,
  "gpu_device_id": -1,
  "initial_strains": [
    {
      "type": 1,
      "count": 20,
      "mu_max": 0.00055,
      "plasmids": ["ColE1"],
      "conjugative": false
    }
  ],
  "hdf5": {
    "enabled": true,
    "schedule": {
      "summary": 1,
      "agents": 0,
      "grid": 0,
      "lineage": 0,
      "genome": 0
    }
  },
  "hdf5_file": "smoke_gpu_output.h5"
}
